{
  "installCommand": "npm install --prefix server && npm install --prefix client",
  "buildCommand": "npm run build",
  "outputDirectory": "client/build",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
